{
  "buildCommand": "PUPPETEER_SKIP_DOWNLOAD=true npm run build:h5",
  "outputDirectory": "dist/build/h5",
  "functions": {
    "api/getWeiDate.js": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/getWeiDate", "destination": "/api/getWeiDate" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
